, 73], [0, 2, 5, 7, 8, 76], [0, 2, 4, 79], [9, 11, 19, 20, 50, 61], [2, 4, 8, 10], [4, 7, 9, 10, 50, 76], [1, 6, 8, 10, 11, 50], [1, 2, 3, 7, 8, 9], [1, 3, 6, 9, 20, 21], [13, 14, 18], [12, 18, 75, 78], [12, 15, 18, 28, 66], [14, 16, 17, 18, 22, 28, 31], [15, 17, 18, 20, 21], [15, 16, 20, 22], [12, 13, 14, 15, 16, 21, 78], [6, 20, 22, 30, 33, 52, 61], [6, 11, 16, 17, 19, 21, 22], [3, 11, 16, 18, 20, 73, 78], [15, 17, 19, 20, 30, 31], [25, 26, 32, 33, 52], [25, 26, 27, 28, 67, 69], [23, 24, 26, 52, 54, 67], [23, 24, 25, 27, 29, 32], [24, 26, 28, 29, 31], [14, 15, 24, 27, 31, 66, 69], [26, 27, 31, 32, 33], [19, 22, 31, 33], [15, 22, 27, 28, 29, 30, 33], [23, 26, 29, 33], [19, 23, 29, 30, 31, 32, 52], [44, 47, 53, 62, 63], [37, 38, 43, 50, 61], [57, 64], [35, 43, 45, 61], [35, 39, 41, 43, 50, 59, 76], [38, 43, 45, 46, 59, 65], [49, 56, 72], [38, 59, 64, 65, 76], [49, 60, 62, 72], [35, 37, 38, 39, 45], [34, 48, 55, 62, 63], [37, 39, 43, 46, 48, 55, 58, 61], [39, 45, 57, 58, 65], [34, 48, 51, 52, 53, 56, 61, 63], [44, 45, 47, 55, 61, 63], [40, 42, 53, 56, 62, 72], [6, 8, 9, 35, 38, 61, 76], [47, 52, 54, 56], [19, 23, 25, 33, 47, 51, 54, 61], [34, 47, 49, 56, 62], [25, 51, 52, 56], [44, 45, 48, 58, 62], [40, 47, 49, 51, 53, 54], [36, 46, 65], [45, 46, 55, 62], [38, 39, 41, 65], [42, 72], [6, 19, 35, 37, 45, 47, 48, 50, 52], [34, 42, 44, 49, 53, 55, 58], [34, 44, 47, 48], [36, 41, 65], [39, 41, 46, 57, 59, 64], [14, 28, 69, 71], [24, 25, 69], [70, 74, 75, 77, 79], [24, 28, 66, 67, 71], [2, 68, 73, 74, 79], [66, 69], [40, 42, 49, 60], [2, 3, 21, 70, 74, 75, 78], [68, 70, 73, 75], [13, 68, 73, 74, 78], [0, 4, 8, 38, 41, 50], [0, 68, 79], [13, 18, 21, 73, 75], [0, 2, 5, 68, 70, 77]], \"note\": \"neighbors[i] is the list of precinct indices that share a boundary with precinct i (4-connected on the rasterized Voronoi map). Use this to compute connected components on an opened site's assigned-precinct subgraph: more than one component means a non-contiguous service area.\"}"}, {