, 2, 6, 11, 12], [1, 2, 12, 75, 76, 77, 79], [0, 1, 2, 4], [0, 8, 11], [0, 3, 7, 9, 11, 20, 59], [1, 3, 8, 10, 40, 53, 59], [1, 9, 40, 77], [0, 4, 7, 8, 12, 15, 16, 20], [2, 4, 5, 11, 16, 70, 76], [14, 15, 16, 22, 70], [13, 15, 17, 18, 21, 22, 32], [11, 13, 14, 16, 20, 21], [11, 12, 13, 15, 70], [14, 18, 22, 68, 73], [14, 17, 24, 29, 32, 73], [70, 75, 76, 79], [8, 11, 15, 21, 25, 28, 31, 59], [14, 15, 20, 25, 32], [13, 14, 17, 70], [24, 26, 27, 28, 29, 31, 66], [18, 23, 29, 66, 72, 73, 74], [20, 21, 26, 28, 29, 32], [23, 25, 28, 29], [23, 30, 31, 33, 66], [20, 23, 25, 26, 31], [18, 23, 24, 25, 26, 32], [27, 33, 36, 66], [20, 23, 27, 28, 33, 59, 61], [14, 18, 21, 25, 29], [27, 30, 31, 36, 44, 61], [38, 51, 57, 67], [38, 40, 51, 53], [30, 33, 44, 60], [42, 47, 49, 54, 63, 64], [34, 35, 50, 51, 53, 57], [41, 50, 58, 62], [9, 10, 35, 51, 53], [39, 54, 55, 62], [37, 45, 46, 49, 54, 55], [48, 50, 54, 62, 63], [33, 36, 52, 56, 60, 61], [42, 46, 55, 65], [42, 45, 49, 56, 60, 65], [37, 48, 53, 59, 63, 64], [43, 47, 50, 53, 63], [37, 42, 46, 52, 56, 64], [38, 39, 43, 48, 53, 57, 58, 62], [34, 35, 38, 40], [44, 49, 56, 61, 64], [9, 35, 38, 40, 47, 48, 50, 59], [37, 41, 42, 43, 55, 62, 63], [41, 42, 45, 54, 65], [44, 46, 49, 52, 60], [34, 38, 50, 58, 67], [39, 50, 57], [8, 9, 20, 31, 47, 53, 61, 64], [36, 44, 46, 56, 65], [31, 33, 44, 52, 59, 64], [39, 41, 43, 50, 54], [37, 43, 47, 48, 54], [37, 47, 49, 52, 59, 61], [45, 46, 55, 60], [23, 24, 27, 30, 72], [34, 57], [17, 71, 73, 78], [72, 78], [12, 13, 16, 19, 22, 76], [68, 72, 74, 78], [24, 66, 69, 71, 74, 78], [17, 18, 24, 68, 74], [24, 71, 72, 73], [5, 19, 77, 79], [5, 12, 19, 70, 79], [1, 5, 10, 75], [68, 69, 71, 72], [5, 19, 75, 76]], \"note\": \"neighbors[i] is the list of precinct indices that share a boundary with precinct i (4-connected on the rasterized Voronoi map). Use this to compute connected components on an opened site's assigned-precinct subgraph: more than one component means a non-contiguous service area.\"}"}